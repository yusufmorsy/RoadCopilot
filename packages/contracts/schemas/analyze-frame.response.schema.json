{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://roadcopilot.local/schemas/analyze-frame.response.json",
  "title": "AnalyzeFrameResponse",
  "type": "object",
  "required": ["requestId", "processedAt", "lane", "advisory"],
  "properties": {
    "requestId": { "type": "string" },
    "processedAt": { "type": "string", "format": "date-time" },
    "lane": {
      "type": "object",
      "required": ["detected", "confidence"],
      "properties": {
        "detected": { "type": "boolean" },
        "offsetNorm": { "type": "number" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "advisory": {
      "type": "object",
      "required": ["message", "severity"],
      "properties": {
        "message": { "type": "string" },
        "severity": {
          "type": "string",
          "enum": ["info", "notice", "caution"]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
