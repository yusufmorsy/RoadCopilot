# RoadCopilot mobile — copy to `.env` in this folder and restart Expo.
# Never commit real keys; `.env` is gitignored.

# Google Maps Platform (Routes API + Geocoding + Android map tiles via react-native-maps).
# Leave empty to use offline demo routes. For Android maps, enable "Maps SDK for Android" on this key.
#
# If Expo Go works but a dev-client / TestFlight / Play build shows "Sample data for demo" and a
# wrong map line, this variable was missing when that JS bundle was produced. Add
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY (same value) in expo.dev → your project → Environment variables,
# then run `eas update` or create a new `eas build`. Local `.env` is not uploaded to EAS.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional separate key for Roads API when you wire live speed limits.
EXPO_PUBLIC_GOOGLE_ROADS_API_KEY=

# Vision service base URL only: no trailing slash, no /analyze-frame path (the app adds that).
# On a real phone, use your computer's Wi‑Fi IP (not localhost). Android emulator: http://10.0.2.2:8000
# Start the API with a reachable bind, e.g. uvicorn main:app --host 0.0.0.0 --port 8000
EXPO_PUBLIC_VISION_API_URL=

# Optional: max wait for each /analyze-frame request in ms (default 18000). Increase on very slow Wi‑Fi.
# EXPO_PUBLIC_VISION_ANALYZE_TIMEOUT_MS=30000

# When location permission is denied, planning uses this origin (decimal degrees).
# Example (San Francisco); replace with your area for demos.
EXPO_PUBLIC_FALLBACK_ORIGIN_LAT=37.7749
EXPO_PUBLIC_FALLBACK_ORIGIN_LNG=-122.4194
