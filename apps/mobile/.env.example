# RoadCopilot mobile — copy to `.env` in this folder and restart Expo.
# Never commit real keys; `.env` is gitignored.

# Google Maps Platform (Routes API + Geocoding). Leave empty to use offline demo routes.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional separate key for Roads API when you wire live speed limits.
EXPO_PUBLIC_GOOGLE_ROADS_API_KEY=

# Vision service base URL (no trailing slash), e.g. http://192.168.1.10:8000
EXPO_PUBLIC_VISION_API_URL=

# When location permission is denied, planning uses this origin (decimal degrees).
# Example (San Francisco); replace with your area for demos.
EXPO_PUBLIC_FALLBACK_ORIGIN_LAT=37.7749
EXPO_PUBLIC_FALLBACK_ORIGIN_LNG=-122.4194
